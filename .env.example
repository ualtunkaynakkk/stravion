# --- Supabase (iletişim formu) ---
# Supabase projenizin Settings > API bölümünden alın.
# anon (publishable) key güvenle istemciye açılabilir; tabloda RLS ile yalnızca INSERT'e izin verilmiştir.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site adresi ---
# Canonical, OG etiketleri ve sitemap bu değerden üretilir. Domain bağlanınca https://stravion.com yapın.
NEXT_PUBLIC_SITE_URL=

# --- Bildirim maili (opsiyonel) ---
# Boş bırakılırsa mail gönderilmez; form kayıtları yine Supabase'e yazılır.
# RESEND_API_KEY: resend.com > API Keys (Sending access yeterli)
# NOTIFY_EMAIL: bildirimin düşeceği adres
# NOTIFY_FROM: domain Resend'de doğrulanınca "STRAVION <bildirim@stravion.com>" yapın.
RESEND_API_KEY=
NOTIFY_EMAIL=
# NOTIFY_FROM=

# --- Analitik (opsiyonel, Faz 5) ---
# NEXT_PUBLIC_ANALYTICS_ID=
